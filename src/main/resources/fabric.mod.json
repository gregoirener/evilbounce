{
  "schemaVersion": 1,
  "id": "liquidbounce",
  "version": "${version}",
  "name": "EvilBounce",
  "description": "A free mixin-based injection hacked-client for Minecraft using the Fabric modding toolchain.",
  "authors": [
    "EvilBounce"
  ],
  "contributors": $contributors,
  "contact": {
    "homepage": "https://github.com/gregoirener/evilbounce",
    "sources": "https://github.com/gregoirener/evilbounce",
    "issues": "https://github.com/gregoirener/evilbounce/issues",
    "email": "support@evilbounce.net"
  },
  "license": "GNU General Public License v3.0",
  "icon": "resources/liquidbounce/icon_64x64.png",
  "environment": "client",
  "entrypoints": {
    "main": []
  },
  "custom": {
    "modmenu": {
      "links": {
        "liquidbounce.generic.forum": "https://github.com/gregoirener/evilbounce"
      }
    }
  },
  "mixins": [
    "liquidbounce.mixins.json"
  ],
  "depends": {
    "minecraft": ["${minecraft_version}"],
    "fabricloader": ">=${min_loader_version}",
    "fabric-language-kotlin": ">=${fabric_kotlin_version}"
  },
  "suggests": {
    "fabric": ">=${fabric_version}",
    "viafabricplus": ">=${viafabricplus_version}"
  },
  "breaks": {
    "viafabricplus": "<${viafabricplus_version}"
  },
  "accessWidener": "liquidbounce.accesswidener"
}
